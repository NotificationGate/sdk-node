{
  "name": "notificationgate",
  "version": "0.1.0",
  "description": "Official Node.js/TypeScript SDK for the NotificationGate email API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "email",
    "transactional",
    "api",
    "sdk",
    "notificationgate"
  ],
  "author": "NotificationGate",
  "license": "MIT",
  "homepage": "https://notificationgate.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/notificationgate/notificationgate"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.0.0"
  }
}
